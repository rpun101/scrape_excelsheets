@page "/"

<PageTitle>Excel Rule Merger</PageTitle>

<div class="container py-5 text-center">
    <h1 class="display-5 fw-bold">&#x1F4CA; Excel Rule Merger</h1>
    <p class="lead mb-4">
        Upload Excel workbooks, filter rows across multiple sheets using configurable rules,
        and download a single merged output file.
    </p>
    <a href="/excel-merger" class="btn btn-success btn-lg px-5">
        Get Started &rarr;
    </a>

    <div class="row g-4 mt-5 text-start">
        <div class="col-md-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">&#x1F50D; Three Filter Modes</h5>
                    <p class="card-text">Extract rows between text markers, filter by exact column value, or filter by date range.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">&#x1F5C2;&#xFE0F; Multi-Sheet Merge</h5>
                    <p class="card-text">Process all sheets or specific ones. Filtered rows from every sheet are merged into a single output table.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">&#x1F4E5; Export Anywhere</h5>
                    <p class="card-text">Download results as an Excel (.xlsx) or CSV file. Errors on individual sheets are logged — processing continues.</p>
                </div>
            </div>
        </div>
    </div>
</div>

